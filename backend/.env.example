# Copy this file to .env and fill in your values

# ── Security ─────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ──────────────────────────────────────────────────────────
# Leave commented out to use SQLite (local dev)
# Uncomment and set for PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/repairhub

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ── Token Expiry (hours) ──────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Admin Seed (used by seed_admin.py only) ───────────────────────────
ADMIN_EMAIL=admin@repairhub.com
ADMIN_PASSWORD=Admin@1234
